{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreExportsUsedInFile": true,
  "entry": [
    "rollup.all.config.mjs",
    "rollup.content.config.mjs",
    "rollup.background.config.mjs",
    "rollup.migration.config.mjs",
    "rollup.visualizer.config.mjs",
    "pages/onboarding/*.js",
    "pages/options/*.js",
    "pages/popup/*.js",
    "pages/sidepanel/*.js",
    "pages/update-notification/*.js",
    "rollup/plugins/assertTestFixtureDce.mjs",
    "rollup/plugins/stripTestConfig.mjs",
    "scripts/postinstall.js",
    "tools/inject-manifest-key.mjs"
  ],
  "project": [
    "scripts/**/*.{js,mjs}",
    "pages/**/*.{js,html}",
    "tests/**/*.js",
    "tools/**/*.{js,mjs}",
    "rollup/**/*.{js,mjs}"
  ],
  "ignore": [
    ".history/**",
    "docs/archive/**",
    "archive/**",
    "lib/**",
    "dist/**",
    "coverage/**",
    ".tmp/**",
    "releases/**",
    "demos/**",
    "site/**",
    "research/**",
    "promo-images/**",
    "icons/**",
    "styles/**",
    "playwright-report/**",
    "test-results/**",
    "node_modules/**",
    "examples/**",
    "scripts/config/env/build.example.js",
    "scripts/config/extension/index.js",
    "tests/e2e/**",
    "tests/helpers/test-constants.js",
    "tests/helpers/test-environment-helper.js"
  ],
  "ignoreIssues": {
    "scripts/utils/imageUtils.js": ["exports"],
    "scripts/background/utils/highlightStyleMerger.js": ["exports"],
    "scripts/background.js": ["exports"],
    "scripts/highlighter/index.js": ["exports"],
    "scripts/config/shared/content.js": ["exports", "duplicates"],
    "scripts/config/shared/messages.js": ["exports"],
    "scripts/config/shared/storage.js": ["exports"],
    "scripts/utils/uiUtils.js": ["exports"],
    "tests/helpers/status-fixtures.js": ["exports"]
  },
  "ignoreBinaries": ["eslint"],
  "ignoreDependencies": [
    "baseline-browser-mapping",
    "eslint-plugin-compat",
    "eslint-plugin-jest",
    "eslint-plugin-jsdoc",
    "eslint-plugin-promise",
    "eslint-plugin-regexp",
    "eslint-plugin-security",
    "eslint-plugin-sonarjs",
    "eslint-plugin-unicorn"
  ]
}
