{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    ".": {
      "release-type": "node",
      "extra-files": ["manifest.json"],
      "include-component-in-tag": false,
      "exclude-paths": [
        "docs/",
        "site/",
        ".agents/",
        ".github/",
        ".gemini/",
        ".husky/",
        "tests/",
        "promo-images/",
        "coverage/",
        ".coderabbit.yaml",
        ".deepsource.toml",
        ".pr_agent.toml",
        ".prettierrc",
        ".prettierignore",
        ".serenaignore",
        "codecov.yml",
        "CODE_OF_CONDUCT.md",
        "babel.config.js",
        "jest.config.js",
        "playwright.config.js",
        "eslint.config.js",
        "README.md",
        "USER_GUIDE.md",
        "LICENSE",
        "CHANGELOG.md",
        "tools/",
        "rollup.all.config.mjs",
        "rollup.background.config.mjs",
        "rollup.content.config.mjs",
        "rollup.migration.config.mjs",
        "rollup.preloader.config.mjs",
        "package-lock.json"
      ],
      "changelog-sections": [
        {
          "type": "feat",
          "section": "✨ 新功能"
        },
        {
          "type": "fix",
          "section": "🐛 Bug 修復"
        },
        {
          "type": "docs",
          "section": "📝 文檔更新",
          "hidden": true
        },
        {
          "type": "style",
          "section": "♻️ 代碼重構"
        },
        {
          "type": "refactor",
          "section": "♻️ 代碼重構"
        },
        {
          "type": "perf",
          "section": "⚡ 效能優化"
        },
        {
          "type": "test",
          "section": "🧪 測試"
        },
        {
          "type": "build",
          "section": "👷 建置與 CI"
        },
        {
          "type": "ci",
          "section": "👷 建置與 CI"
        },
        {
          "type": "chore",
          "section": "🧹 其他變更"
        }
      ]
    }
  }
}
