{
  "description": "Chrome Extension Storage Schema Definition",
  "source_of_truth": "scripts/background/services/StorageService.js",
  "storage_areas": {
    "local": {
      "limits": "5MB (unlimitedStorage permission)",
      "keys": {
        "notionAuthEpoch": {
          "type": "number",
          "description": "Monotonic epoch for OAuth auth-state mutations across contexts; used to detect stale refresh writes",
          "default": 0
        }
      },
      "patterns": {
        "page_{stableUrl}": {
          "description": "Unified page state (Phase 3 Architecture) containing Notion saved status and local highlights",
          "schema": {
            "notion": {
              "type": "object | null",
              "description": "Notion metadata and synchronization status. Null if highlights exist but not saved to Notion.",
              "properties": {
                "pageId": "string (UUID)",
                "url": "string (https://www.notion.so/...)",
                "title": "string",
                "savedAt": "number (timestamp ms)",
                "lastVerifiedAt": "number (timestamp ms)"
              }
            },
            "highlights": {
              "type": "array",
              "description": "List of highlights for the specific page",
              "items": {
                "id": "string (UUID)",
                "text": "string (Content)",
                "color": "string (notion color name)",
                "rangeInfo": "object (DOM selection info)",
                "timestamp": "number (timestamp ms)"
              }
            },
            "metadata": {
              "type": "object",
              "properties": {
                "createdAt": "number (timestamp ms)",
                "lastUpdated": "number (timestamp ms)",
                "migratedFrom": "string (optional, e.g., highlights_URL)"
              }
            }
          }
        },
        "url_alias_{normalizedUrl}": {
          "description": "Mapping from original URL to stable URL to handle async race conditions",
          "schema": "string (stableUrl)"
        }
      }
    },
    "sync": {
      "limits": "100KB total, 8KB per item",
      "keys": {
        "notionApiKey": {
          "type": "string",
          "description": "Notion Integration Secret (Bearer Token)",
          "sensitive": true
        },
        "notionDatabaseId": {
          "type": "string",
          "description": "Default target database ID"
        },
        "notionDataSourceId": {
          "type": "string",
          "description": "Selected data source ID (db or page)"
        },
        "notionDataSourceType": {
          "type": "string",
          "enum": ["database", "page"],
          "default": "database"
        },
        "themeMode": {
          "type": "string",
          "enum": ["light", "dark", "auto"]
        }
      }
    }
  }
}
