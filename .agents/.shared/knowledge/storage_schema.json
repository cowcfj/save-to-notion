{
  "description": "Chrome Extension Storage Schema Definition",
  "source_of_truth": "scripts/background/services/StorageService.js",
  "storage_areas": {
    "local": {
      "limits": "5MB (unlimitedStorage permission)",
      "keys": {
        "notionAuthMode": {
          "type": "string",
          "enum": ["oauth", "manual"],
          "description": "Current authentication mode"
        },
        "notionOAuthToken": {
          "type": "string",
          "description": "OAuth access token",
          "sensitive": true
        },
        "notionRefreshToken": {
          "type": "string",
          "description": "OAuth refresh token",
          "sensitive": true
        },
        "notionRefreshProof": {
          "type": "string | null",
          "description": "OAuth refresh proof (if provided by server)",
          "sensitive": true
        },
        "notionWorkspaceName": {
          "type": "string",
          "description": "Notion workspace name for OAuth display"
        },
        "notionAuthEpoch": {
          "type": "number",
          "description": "Monotonic epoch for OAuth auth-state mutations across contexts; used to detect stale refresh writes",
          "default": 0
        },
        "notionDataSourceId": {
          "type": "string",
          "description": "Selected data source ID (db or page)"
        },
        "notionDatabaseId": {
          "type": "string",
          "description": "Legacy database ID (compat fallback)"
        },
        "notionDataSourceType": {
          "type": "string",
          "enum": ["database", "page"],
          "default": "database"
        },
        "$comment_account": "=== Account Session Keys (Cloudflare-native, Phase 1) ===\n以下 key 全部以 account 前綴命名，與 Notion OAuth keys 完整隔離。\n來源：scripts/auth/accountSession.js",
        "accountAccessToken": {
          "type": "string",
          "description": "Bearer token，用於呼叫 /v1/account/* 端點",
          "sensitive": true
        },
        "accountRefreshToken": {
          "type": "string",
          "description": "Refresh token；Phase 2 reserved，Phase 1 寫入但不使用",
          "sensitive": true
        },
        "accountAccessTokenExpiresAt": {
          "type": "number",
          "description": "Unix timestamp（秒）；前端比較時須 × 1000 轉為毫秒"
        },
        "accountUserId": {
          "type": "string",
          "description": "後端回傳的 user ID"
        },
        "accountEmail": {
          "type": "string",
          "description": "帳號 email，用於 Options UI 顯示。⚠️ PII：MUST NOT 直接寫入日誌，LogSanitizer 已透過 SENSITIVE_KEY_PATTERN 自動脫敏",
          "sensitive": true
        },
        "accountDisplayName": {
          "type": "string | null",
          "description": "帳號顯示名稱（可能為 null）"
        },
        "accountAvatarUrl": {
          "type": "string | null",
          "description": "帳號頭像 URL（可能為 null）"
        },
        "$comment_driveSync": "=== Google Drive Sync Metadata Keys (Phase A) ===\n所有 key 以 driveSync 前綴命名，與 account / notion keys 完整隔離。\n不包含任何 token 或 credential。\n來源：docs/plans/2026-04-20-google-drive-sync-frontend-phase-a-manual-sync-plan.md §5.3",
        "driveSyncConnectionEmail": {
          "type": "string | null",
          "description": "已連接的 Google Drive 帳號 email。⚠️ PII：MUST NOT 直接寫入日誌",
          "sensitive": true
        },
        "driveSyncConnectedAt": {
          "type": "string | null",
          "description": "Drive 授權完成時間（ISO 8601）"
        },
        "driveSyncLastKnownRemoteUpdatedAt": {
          "type": "string | null",
          "description": "上次查詢時後端回傳的 snapshot updatedAt（ISO 8601）；用於 conflict 偵測"
        },
        "driveSyncLastSuccessfulUploadAt": {
          "type": "string | null",
          "description": "上次成功上傳完成的本地記錄時間（ISO 8601）"
        },
        "driveSyncLastSuccessfulDownloadAt": {
          "type": "string | null",
          "description": "上次成功下載並套用完成的本地記錄時間（ISO 8601）"
        },
        "driveSyncLastErrorCode": {
          "type": "string | null",
          "description": "上次同步失敗的錯誤代碼，例如 REMOTE_SNAPSHOT_NEWER, NETWORK_ERROR"
        },
        "driveSyncLastErrorAt": {
          "type": "string | null",
          "description": "上次同步失敗的時間（ISO 8601）"
        },
        "driveSyncLastRunAt": {
          "type": "string | null",
          "description": "上次執行同步操作（無論成敗）的時間（ISO 8601）"
        },
        "driveSyncLastRunType": {
          "type": "string | null",
          "enum": ["upload", "download", "status_check"],
          "description": "上次同步操作的類型"
        },
        "driveSyncNeedsManualReview": {
          "type": "boolean",
          "description": "true 表示目前有待人工處理的衝突（例如 REMOTE_SNAPSHOT_NEWER 尚未解決）",
          "default": false
        },
        "driveSyncInstallationId": {
          "type": "string | null",
          "description": "此 extension 安裝的唯一識別碼，用於後端區分同一帳號的多個 extension 安裝"
        },
        "driveSyncProfileId": {
          "type": "string | null",
          "description": "後端 Drive profile ID（若後端有提供），用於對應 snapshot 擁有者"
        }
      },
      "patterns": {
        "page_{stableUrl}": {
          "description": "Unified page state (Phase 3 Architecture) containing Notion saved status and local highlights",
          "schema": {
            "notion": {
              "type": "object | null",
              "description": "Notion metadata and synchronization status. Null if highlights exist but not saved to Notion.",
              "properties": {
                "pageId": "string (UUID)",
                "url": "string (https://www.notion.so/...)",
                "title": "string",
                "savedAt": "number (timestamp ms)",
                "lastVerifiedAt": "number (timestamp ms)"
              }
            },
            "highlights": {
              "type": "array",
              "description": "List of highlights for the specific page",
              "items": {
                "id": "string (UUID)",
                "text": "string (Content)",
                "color": "string (notion color name)",
                "rangeInfo": "object (DOM selection info)",
                "timestamp": "number (timestamp ms)"
              }
            },
            "metadata": {
              "type": "object",
              "properties": {
                "createdAt": "number (timestamp ms)",
                "lastUpdated": "number (timestamp ms)",
                "migratedFrom": "string (optional, e.g., highlights_URL)"
              }
            }
          }
        },
        "url_alias_{normalizedUrl}": {
          "description": "Mapping from original URL to stable URL to handle async race conditions",
          "schema": "string (stableUrl)"
        }
      }
    },
    "sync": {
      "limits": "100KB total, 8KB per item",
      "keys": {
        "notionApiKey": {
          "type": "string",
          "description": "Notion Integration Secret (Bearer Token)",
          "sensitive": true
        },
        "titleTemplate": {
          "type": "string",
          "description": "Title template for saved pages"
        },
        "addSource": {
          "type": "boolean",
          "description": "Whether to append source URL"
        },
        "addTimestamp": {
          "type": "boolean",
          "description": "Whether to append timestamp"
        },
        "highlightStyle": {
          "type": "string",
          "description": "Highlight style in saved content"
        },
        "highlightContentStyle": {
          "type": "string",
          "description": "Highlight content sync style"
        },
        "enableDebugLogs": {
          "type": "boolean",
          "description": "Enable debug logging"
        },
        "uiZoomLevel": {
          "type": "string",
          "description": "UI zoom level setting"
        },
        "notionDatabaseId": {
          "type": "string",
          "description": "Legacy database ID (compat fallback)"
        },
        "notionDataSourceId": {
          "type": "string",
          "description": "Selected data source ID (legacy fallback)"
        },
        "notionDataSourceType": {
          "type": "string",
          "enum": ["database", "page"],
          "default": "database"
        },
        "themeMode": {
          "type": "string",
          "enum": ["light", "dark", "auto"]
        }
      }
    }
  }
}
