{
  "description": "Chrome Extension Storage Schema Definition",
  "source_of_truth": "scripts/background/services/StorageService.js",
  "storage_areas": {
    "local": {
      "limits": "5MB (unlimitedStorage permission)",
      "keys": {
        "notionAuthMode": {
          "type": "string",
          "enum": ["oauth", "manual"],
          "description": "Current authentication mode"
        },
        "notionOAuthToken": {
          "type": "string",
          "description": "OAuth access token",
          "sensitive": true
        },
        "notionRefreshToken": {
          "type": "string",
          "description": "OAuth refresh token",
          "sensitive": true
        },
        "notionRefreshProof": {
          "type": "string | null",
          "description": "OAuth refresh proof (if provided by server)",
          "sensitive": true
        },
        "notionWorkspaceName": {
          "type": "string",
          "description": "Notion workspace name for OAuth display"
        },
        "notionAuthEpoch": {
          "type": "number",
          "description": "Monotonic epoch for OAuth auth-state mutations across contexts; used to detect stale refresh writes",
          "default": 0
        },
        "notionDataSourceId": {
          "type": "string",
          "description": "Selected data source ID (db or page)"
        },
        "notionDatabaseId": {
          "type": "string",
          "description": "Legacy database ID (compat fallback)"
        },
        "notionDataSourceType": {
          "type": "string",
          "enum": ["database", "page"],
          "default": "database"
        },
        "$comment_account": "=== Account Session Keys (Cloudflare-native, Phase 1) ===\n以下 key 全部以 account 前綴命名，與 Notion OAuth keys 完整隔離。\n來源：scripts/auth/accountSession.js",
        "accountAccessToken": {
          "type": "string",
          "description": "Bearer token，用於呼叫 /v1/account/* 端點",
          "sensitive": true
        },
        "accountRefreshToken": {
          "type": "string",
          "description": "Refresh token；Phase 2 reserved，Phase 1 寫入但不使用",
          "sensitive": true
        },
        "accountAccessTokenExpiresAt": {
          "type": "number",
          "description": "Unix timestamp（秒）；前端比較時須 × 1000 轉為毫秒"
        },
        "accountUserId": {
          "type": "string",
          "description": "後端回傳的 user ID"
        },
        "accountEmail": {
          "type": "string",
          "description": "帳號 email，用於 Options UI 顯示"
        },
        "accountDisplayName": {
          "type": "string | null",
          "description": "帳號顯示名稱（可能為 null）"
        },
        "accountAvatarUrl": {
          "type": "string | null",
          "description": "帳號頭像 URL（可能為 null）"
        }
      },
      "patterns": {
        "page_{stableUrl}": {
          "description": "Unified page state (Phase 3 Architecture) containing Notion saved status and local highlights",
          "schema": {
            "notion": {
              "type": "object | null",
              "description": "Notion metadata and synchronization status. Null if highlights exist but not saved to Notion.",
              "properties": {
                "pageId": "string (UUID)",
                "url": "string (https://www.notion.so/...)",
                "title": "string",
                "savedAt": "number (timestamp ms)",
                "lastVerifiedAt": "number (timestamp ms)"
              }
            },
            "highlights": {
              "type": "array",
              "description": "List of highlights for the specific page",
              "items": {
                "id": "string (UUID)",
                "text": "string (Content)",
                "color": "string (notion color name)",
                "rangeInfo": "object (DOM selection info)",
                "timestamp": "number (timestamp ms)"
              }
            },
            "metadata": {
              "type": "object",
              "properties": {
                "createdAt": "number (timestamp ms)",
                "lastUpdated": "number (timestamp ms)",
                "migratedFrom": "string (optional, e.g., highlights_URL)"
              }
            }
          }
        },
        "url_alias_{normalizedUrl}": {
          "description": "Mapping from original URL to stable URL to handle async race conditions",
          "schema": "string (stableUrl)"
        }
      }
    },
    "sync": {
      "limits": "100KB total, 8KB per item",
      "keys": {
        "notionApiKey": {
          "type": "string",
          "description": "Notion Integration Secret (Bearer Token)",
          "sensitive": true
        },
        "titleTemplate": {
          "type": "string",
          "description": "Title template for saved pages"
        },
        "addSource": {
          "type": "boolean",
          "description": "Whether to append source URL"
        },
        "addTimestamp": {
          "type": "boolean",
          "description": "Whether to append timestamp"
        },
        "highlightStyle": {
          "type": "string",
          "description": "Highlight style in saved content"
        },
        "highlightContentStyle": {
          "type": "string",
          "description": "Highlight content sync style"
        },
        "enableDebugLogs": {
          "type": "boolean",
          "description": "Enable debug logging"
        },
        "uiZoomLevel": {
          "type": "string",
          "description": "UI zoom level setting"
        },
        "notionDatabaseId": {
          "type": "string",
          "description": "Legacy database ID (compat fallback)"
        },
        "notionDataSourceId": {
          "type": "string",
          "description": "Selected data source ID (legacy fallback)"
        },
        "notionDataSourceType": {
          "type": "string",
          "enum": ["database", "page"],
          "default": "database"
        },
        "themeMode": {
          "type": "string",
          "enum": ["light", "dark", "auto"]
        }
      }
    }
  }
}
