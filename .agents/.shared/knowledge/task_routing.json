{
  "description": "Canonical task routing map for choosing the right guide, knowledge file, and plan level.",
  "source_of_truth": "docs/guides/TASK_ROUTING.md",
  "cross_cutting": {
    "guides": ["docs/guides/TOOL_AND_BOUNDARY_GUIDE.md"],
    "knowledge": [".agents/.shared/knowledge/tool_boundaries.json"],
    "note": "適用於所有 task types，在進入特定 task type 前載入。"
  },
  "task_types": {
    "bug_fix": {
      "guides": ["docs/guides/DEBUGGING_GUIDE.md", "docs/guides/TESTING_GUIDE.md"],
      "knowledge": [".agents/.shared/knowledge/debugging_rules.json"],
      "default_plan_level": "lite_or_standard",
      "completion": {
        "lite": "May use Lite Completion Path and skip doc_impact_matrix.json.",
        "standard": "Read docs/guides/CHANGE_COMPLETION_WORKFLOW.md and check doc_impact_matrix.json bug_fix."
      }
    },
    "feature": {
      "guides": [
        "docs/guides/ARCHITECTURE_DECISION_GUIDE.md",
        "docs/guides/TESTING_GUIDE.md",
        "docs/guides/DOCUMENTATION_STRATEGY.md",
        "docs/guides/CHANGE_COMPLETION_WORKFLOW.md"
      ],
      "knowledge": [
        ".agents/.shared/knowledge/message_bus.json",
        ".agents/.shared/knowledge/storage_schema.json",
        ".agents/.shared/knowledge/notion_constraints.json",
        ".agents/.shared/knowledge/security_rules.json"
      ],
      "default_plan_level": "standard_or_deep",
      "completion": {
        "standard_or_deep": "Use Plan-Driven Completion Path and check doc_impact_matrix.json feature."
      }
    },
    "refactor": {
      "guides": [
        "docs/guides/REFACTORING_BEST_PRACTICES.md",
        "docs/guides/ARCHITECTURE_DECISION_GUIDE.md",
        "docs/guides/TESTING_GUIDE.md",
        "docs/guides/CHANGE_COMPLETION_WORKFLOW.md"
      ],
      "knowledge": [
        ".agents/.shared/knowledge/message_bus.json",
        ".agents/.shared/knowledge/storage_schema.json",
        ".agents/.shared/knowledge/security_rules.json"
      ],
      "default_plan_level": "standard_or_deep",
      "completion": {
        "standard_or_deep": "Use Plan-Driven Completion Path and check doc_impact_matrix.json refactor."
      }
    },
    "review": {
      "guides": ["docs/guides/CODE_REVIEW_GUIDE.md"],
      "knowledge": [".agents/.shared/knowledge/review_red_lines.json"],
      "default_plan_level": "lite",
      "completion": {
        "lite": "May use Lite Completion Path; doc checks are not required unless review policy docs are changed."
      }
    },
    "doc_report": {
      "guides": ["docs/guides/DOCUMENTATION_STRATEGY.md"],
      "knowledge": [".agents/.shared/knowledge/plan_policy.json"],
      "default_plan_level": "lite_or_standard",
      "completion": {
        "lite": "May use Lite Completion Path and skip doc_impact_matrix.json.",
        "standard": "Read docs/guides/CHANGE_COMPLETION_WORKFLOW.md and use doc_impact_matrix.json when documentation synchronization is in scope."
      }
    },
    "backend_boundary_investigation": {
      "guides": [
        "docs/guides/DEBUGGING_GUIDE.md",
        "docs/guides/ARCHITECTURE_DECISION_GUIDE.md",
        "docs/guides/CHANGE_COMPLETION_WORKFLOW.md"
      ],
      "knowledge": [
        ".agents/.shared/knowledge/message_bus.json",
        ".agents/.shared/knowledge/storage_schema.json",
        ".agents/.shared/knowledge/security_rules.json"
      ],
      "default_plan_level": "deep",
      "completion": {
        "deep": "Use Plan-Driven Completion Path and check doc_impact_matrix.json decision_change or bug_fix."
      }
    }
  }
}
