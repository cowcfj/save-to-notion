{
  "description": "Chrome Extension Runtime Message Bus Registry",
  "source_of_truth": {
    "action_names": "scripts/config/runtimeActions.js",
    "runtime_behavior": "scripts/background/handlers/*.js, scripts/content/index.js, scripts/highlighter/entryAutoInit.js, scripts/performance/preloader.js"
  },
  "maintenance_rule": "新增、刪除或改名任何 runtime/tabs message action 時，必須先更新 scripts/config/runtimeActions.js，再同步更新本檔的 payload/response contract。",
  "actions": {
    "save": {
      "savePage": {
        "description": "從 Popup 或 Side Panel 觸發頁面保存流程",
        "payload": {},
        "response": {
          "success": "boolean",
          "statusKind": "\"saved\" | \"unsaved\" | \"deletion_pending\" | \"deleted_remote\" | \"unverified_saved\" | \"error\" (optional)",
          "isSaved": "boolean (optional)",
          "canSave": "boolean (optional)",
          "canSyncHighlights": "boolean (optional)",
          "stableUrl": "string (optional)",
          "url": "string (optional)",
          "pageId": "string (optional)",
          "notionPageId": "string (optional)",
          "notionUrl": "string (optional)",
          "title": "string (optional)",
          "error": "string (optional)"
        }
      },
      "SAVE_PAGE_FROM_TOOLBAR": {
        "description": "從 Highlighter Toolbar 觸發保存流程",
        "payload": {},
        "response": {
          "success": "boolean",
          "statusKind": "\"saved\" | \"unsaved\" | \"deletion_pending\" | \"deleted_remote\" | \"unverified_saved\" | \"error\" (optional)",
          "isSaved": "boolean (optional)",
          "canSave": "boolean (optional)",
          "canSyncHighlights": "boolean (optional)",
          "stableUrl": "string (optional)",
          "url": "string (optional)",
          "pageId": "string (optional)",
          "notionPageId": "string (optional)",
          "notionUrl": "string (optional)",
          "title": "string (optional)",
          "error": "string (optional)"
        }
      },
      "openNotionPage": {
        "description": "依已保存頁面資料開啟對應 Notion 頁面",
        "payload": {
          "url": "string"
        },
        "response": {
          "success": "boolean",
          "tabId": "number (optional)",
          "error": "string (optional)"
        }
      },
      "checkNotionPageExists": {
        "description": "檢查指定 Notion pageId 是否仍存在",
        "payload": {
          "pageId": "string"
        },
        "response": {
          "success": "boolean",
          "exists": "boolean (optional)",
          "error": "string (optional)"
        }
      },
      "checkPageStatus": {
        "description": "檢查當前頁面是否已保存，Background 會回傳 canonical save status contract",
        "payload": {
          "forceRefresh": "boolean (optional)",
          "url": "string (optional)"
        },
        "response": {
          "success": "boolean",
          "statusKind": "\"saved\" | \"unsaved\" | \"deletion_pending\" | \"deleted_remote\" | \"unverified_saved\" | \"error\" (optional)",
          "isSaved": "boolean (optional)",
          "canSave": "boolean (optional)",
          "canSyncHighlights": "boolean (optional)",
          "notionPageId": "string (optional)",
          "notionUrl": "string (optional)",
          "title": "string (optional)",
          "stableUrl": "string (optional)",
          "wasDeleted": "boolean (optional)",
          "deletionPending": "boolean (optional)",
          "error": "string (optional)"
        }
      },
      "PAGE_SAVE_HINT": {
        "description": "Background 對 content script 的最佳努力推播，提示頁面已保存",
        "payload": {
          "isSaved": "boolean"
        },
        "response": {
          "success": "boolean (optional)"
        }
      }
    },
    "highlight": {
      "USER_ACTIVATE_SHORTCUT": {
        "description": "Preloader 將快捷鍵事件上送至 Background",
        "payload": {},
        "response": {
          "success": "boolean",
          "error": "string (optional)"
        }
      },
      "startHighlight": {
        "description": "啟動高亮工具，必要時注入 bundle 並顯示 highlighter",
        "payload": {},
        "response": {
          "success": "boolean",
          "error": "string (optional)"
        }
      },
      "toggleHighlighter": {
        "description": "切換 highlighter 啟用狀態",
        "payload": {},
        "response": {
          "success": "boolean",
          "isActive": "boolean (optional)",
          "error": "string (optional)"
        }
      },
      "showHighlighter": {
        "description": "要求已注入的 content bundle 顯示 highlighter",
        "payload": {},
        "response": {
          "success": "boolean",
          "error": "string (optional)"
        }
      },
      "showToolbar": {
        "description": "要求已初始化的 Highlighter 顯示 Toolbar",
        "payload": {},
        "response": {
          "success": "boolean",
          "error": "string (optional)"
        }
      },
      "updateHighlights": {
        "description": "將目前頁面的 highlights 同步到 Notion 的 highlights section",
        "payload": {},
        "response": {
          "success": "boolean",
          "highlightsUpdated": "boolean (optional)",
          "highlightCount": "number (optional)",
          "error": "string (optional)"
        }
      },
      "syncHighlights": {
        "description": "以 content script 提供的 highlights 陣列同步到 Notion；支援遠端頁面刪除的兩階段確認",
        "payload": {
          "highlights": "array"
        },
        "response": {
          "success": "boolean",
          "count": "number (optional)",
          "errorCode": "\"PAGE_DELETION_PENDING\" | \"PAGE_DELETED\" | string (optional)",
          "error": "string (optional)"
        }
      },
      "UPDATE_HIGHLIGHTS": {
        "description": "透過 canonical Background storage path 更新本地 highlights（不直接觸發 Notion 同步）",
        "payload": {
          "url": "string",
          "highlights": "array"
        },
        "response": {
          "success": "boolean",
          "error": {
            "code": "string (optional)",
            "message": "string (optional)"
          }
        }
      },
      "CLEAR_HIGHLIGHTS": {
        "description": "透過 canonical Background storage path 清空本地 highlights，並最佳努力清理頁面視覺狀態",
        "payload": {
          "url": "string",
          "tabId": "number (optional)"
        },
        "response": {
          "success": "boolean",
          "clearedCount": "number (optional)",
          "visualCleared": "boolean (optional)",
          "error": "string | object (optional)"
        }
      },
      "GET_STABLE_URL": {
        "description": "向 content script 讀取目前解析出的 stable URL",
        "payload": {},
        "response": {
          "stableUrl": "string (optional)"
        }
      },
      "SET_STABLE_URL": {
        "description": "Background 對 content/highlighter 推送解析出的 stable URL",
        "payload": {
          "stableUrl": "string"
        },
        "response": {
          "success": "boolean (optional)",
          "error": "string (optional)"
        }
      },
      "REMOVE_HIGHLIGHT_DOM": {
        "description": "Side Panel 要求 content script 移除指定 highlight 的 DOM 呈現",
        "payload": {
          "highlightId": "string"
        },
        "response": {
          "success": "boolean (optional)",
          "error": "string (optional)"
        }
      }
    },
    "sidepanel": {
      "OPEN_SIDE_PANEL": {
        "description": "Toolbar 要求 Background 開啟 Chrome Side Panel",
        "payload": {
          "tabId": "number (optional)"
        },
        "response": {
          "success": "boolean",
          "error": "string (optional)"
        }
      }
    },
    "auth": {
      "searchNotion": {
        "description": "Options 頁面查詢 Notion data sources / pages",
        "payload": {
          "apiKey": "string (optional)",
          "searchParams": "object"
        },
        "response": {
          "success": "boolean",
          "data": "object (optional)",
          "error": "string (optional)"
        }
      },
      "refreshOAuthToken": {
        "description": "非 Background context 將 OAuth refresh 委派給 Background 協調",
        "payload": {},
        "response": {
          "success": "boolean",
          "token": "string | null",
          "error": "string (optional)"
        }
      },
      "oauth_success": {
        "description": "OAuth 流程成功後通知 Options UI 刷新狀態",
        "payload": {},
        "response": {
          "success": "boolean (optional)"
        }
      },
      "oauth_failed": {
        "description": "OAuth 流程失敗後通知 Options UI 顯示錯誤",
        "payload": {},
        "response": {
          "success": "boolean (optional)"
        }
      }
    },
    "accountSession": {
      "$comment": "Cloudflare-native account session events — Phase 1\n禁止與 auth.notionOAuth actions 混用；storage keys 皆以 account 前綴隔離",
      "account_session_updated": {
        "description": "auth.html 完成 session exchange + account/me 後廣播；接收方重新讀取 chrome.storage.local",
        "direction": "auth.html → options / background",
        "payload": {
          "userId": "string",
          "email": "string"
        },
        "response": {
          "success": "boolean (optional)"
        }
      },
      "account_session_cleared": {
        "description": "使用者完成本地登出（clear account* keys）後廣播；接收方更新 UI 為未登入狀態",
        "direction": "options → background (optional)",
        "payload": {},
        "response": {
          "success": "boolean (optional)"
        }
      }
    },
    "logging": {
      "exportDebugLogs": {
        "description": "Options 匯出目前緩衝的 debug logs",
        "payload": {
          "format": "\"json\" | \"txt\""
        },
        "response": {
          "success": "boolean",
          "data": "object (optional)",
          "error": "string (optional)"
        }
      },
      "devLogSink": {
        "description": "單筆外部日誌轉發到 Background log buffer",
        "payload": {
          "level": "string",
          "message": "string",
          "args": "array"
        },
        "response": {
          "success": "boolean",
          "error": "string (optional)"
        }
      },
      "devLogSinkBatch": {
        "description": "批量外部日誌轉發到 Background log buffer",
        "payload": {
          "logs": "array"
        },
        "response": {
          "success": "boolean",
          "error": "string (optional)"
        }
      }
    },
    "migration": {
      "migration_execute": {
        "description": "單頁內容感知遷移",
        "payload": {
          "url": "string"
        },
        "response": {
          "success": "boolean",
          "error": "string (optional)"
        }
      },
      "migration_delete": {
        "description": "刪除指定 URL 的舊版標註資料",
        "payload": {
          "url": "string"
        },
        "response": {
          "success": "boolean",
          "message": "string (optional)",
          "error": "string (optional)"
        }
      },
      "migration_batch": {
        "description": "批量遷移多個 URL 的舊版標註資料",
        "payload": {
          "urls": "array"
        },
        "response": {
          "success": "boolean",
          "results": "object (optional)",
          "error": "string (optional)"
        }
      },
      "migration_batch_delete": {
        "description": "批量刪除多個 URL 的舊版標註資料",
        "payload": {
          "urls": "array"
        },
        "response": {
          "success": "boolean",
          "count": "number (optional)",
          "error": "string (optional)"
        }
      },
      "migration_get_pending": {
        "description": "列出待完成定位與失敗的遷移項目",
        "payload": {},
        "response": {
          "success": "boolean",
          "items": "array (optional)",
          "failedItems": "array (optional)",
          "error": "string (optional)"
        }
      },
      "migration_delete_failed": {
        "description": "刪除指定 URL 中已標記為 failed 的舊版標註",
        "payload": {
          "url": "string"
        },
        "response": {
          "success": "boolean",
          "error": "string (optional)"
        }
      }
    },
    "bundle": {
      "PING": {
        "description": "Background 檢查 preloader 或 content bundle 是否就緒，並讀取頁面元資料",
        "payload": {},
        "response": {
          "status": "\"preloader_only\" | \"bundle_ready\" | string (optional)",
          "hasCache": "boolean (optional)",
          "hasPreloaderCache": "boolean (optional)",
          "nextRouteInfo": "object | null (optional)",
          "shortlink": "string | null (optional)"
        }
      },
      "INIT_BUNDLE": {
        "description": "Preloader 對主 bundle 暴露初始化握手資訊",
        "payload": {},
        "response": {
          "ready": "boolean",
          "bufferedEvents": "number (optional)"
        }
      },
      "REPLAY_BUFFERED_EVENTS": {
        "description": "主 bundle 要求 preloader 重放在注入前緩衝的事件",
        "payload": {},
        "response": {
          "events": "array"
        }
      }
    },
    "driveSync": {
      "$comment": "Google Drive Sync Phase A — 手動 connect / upload / download / disconnect\n禁止與 account session actions 混用觸發條件。storage keys 皆以 driveSync 前綴隔離。",
      "DRIVE_CONNECTION_UPDATED": {
        "description": "可選的 Drive UI refresh signal；options listener 收到後可重新整理 Cloud Sync card，但 connect / disconnect 主流程不依賴此 action，現行 production flow 以 DriveCloudSyncController.syncRemoteDriveConnection() 主動重拉狀態為主",
        "direction": "runtime → options (optional)",
        "payload": {
          "email": "string | null — 連線帳號 email，null 表示已斷線",
          "connectedAt": "string | null — ISO 8601 timestamp"
        },
        "response": {
          "success": "boolean (optional)"
        }
      },
      "DRIVE_SYNC_STATUS_UPDATED": {
        "description": "手動 upload/download 完成或 status 查詢後廣播；接收方重新讀取 driveSyncLast* metadata",
        "direction": "background → options",
        "payload": {
          "lastKnownRemoteUpdatedAt": "string | null — 後端 snapshot updatedAt（ISO 8601）",
          "lastSuccessfulUploadAt": "string | null — 本地記錄的上次上傳時間（ISO 8601）"
        },
        "response": {
          "success": "boolean (optional)"
        }
      },
      "DRIVE_SYNC_MANUAL_UPLOAD": {
        "description": "Options UI 要求 Background 執行手動上傳；force=true 用於使用者二次確認後強制覆蓋",
        "direction": "options → background",
        "payload": {
          "force": "boolean (optional) — 強制覆蓋遠端，需使用者二次確認"
        },
        "response": {
          "success": "boolean",
          "error": "string (optional)",
          "errorCode": "\"REMOTE_SNAPSHOT_NEWER\" | string (optional)",
          "remoteUpdatedAt": "string | null (optional) — 發生衝突時的遠端 snapshot updatedAt",
          "updatedAt": "string | null (optional) — 成功時的遠端 snapshot updatedAt"
        }
      },
      "DRIVE_SYNC_MANUAL_DOWNLOAD": {
        "description": "Options UI 要求 Background 執行手動下載並套用本地；套用前需二次確認",
        "direction": "options → background",
        "payload": {},
        "response": {
          "success": "boolean",
          "error": "string (optional)",
          "writtenKeys": "number (optional) — 已套用的 storage key 數量"
        }
      },
      "DRIVE_SYNC_CONFLICT": {
        "description": "Background 在 upload 時偵測到 REMOTE_SNAPSHOT_NEWER 衝突，通知 UI 進入警告流程",
        "direction": "background → options",
        "payload": {
          "conflictType": "\"REMOTE_SNAPSHOT_NEWER\"",
          "remoteUpdatedAt": "string — 遠端 snapshot updatedAt（ISO 8601）"
        },
        "response": {
          "success": "boolean (optional)"
        }
      }
    }
  }
}
