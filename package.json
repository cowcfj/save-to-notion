{
  "name": "notion-smart-clipper",
  "version": "2.66.0",
  "description": "智能網頁擷取工具，支持網站 Icon、封面圖提取、增強的圖片提取、模板自定義、多顏色標註功能，一鍵保存到 Notion。",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "NODE_OPTIONS=--localstorage-file=/tmp/jest-localstorage jest --config jest.config.js",
    "test:watch": "NODE_OPTIONS=--localstorage-file=/tmp/jest-localstorage jest --config jest.config.js --watch",
    "test:coverage": "NODE_OPTIONS=--localstorage-file=/tmp/jest-localstorage jest --config jest.config.js --coverage",
    "test:quick": "NODE_OPTIONS=--localstorage-file=/tmp/jest-localstorage jest --config jest.config.js --onlyChanged --coverage",
    "test:ci": "NODE_OPTIONS=--localstorage-file=/tmp/jest-localstorage jest --config jest.config.js --ci --coverage --maxWorkers=2",
    "test:e2e": "npm run build:prod && playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:merge-coverage": "node tests/e2e/coverage-merger.js",
    "test:all": "npm run test:coverage && npm run test:e2e && npm run test:merge-coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:report": "eslint . --format json --output-file docs/reports/eslint_report.json",
    "format": "prettier --write \"**/*.{js,json,md,html}\"",
    "format:check": "prettier --check \"**/*.{js,json,md,html}\"",
    "postinstall": "node scripts/postinstall.js && npm run build",
    "build": "rollup -c rollup.all.config.mjs",
    "build:watch": "rollup -c rollup.all.config.mjs -w",
    "build:prod": "NODE_ENV=production rollup -c rollup.all.config.mjs",
    "build:prod:analyze": "ANALYZE_BUNDLE=true NODE_ENV=production rollup -c rollup.all.config.mjs",
    "build:content": "rollup -c rollup.content.config.mjs",
    "build:content:watch": "rollup -c rollup.content.config.mjs -w",
    "build:content:prod": "NODE_ENV=production rollup -c rollup.content.config.mjs",
    "build:all": "npm run build",
    "build:all:prod": "NODE_ENV=production npm run build:prod",
    "dev": "npm run build:watch",
    "ext": "npm run build:prod && npm run package:local-unpacked",
    "package:local-unpacked": "bash tools/package-extension.sh --unpacked-dir=.tmp/extension-unpacked --skip-zip --manifest-key-file=\"$HOME/.config/notion-chrome/dev-extension-public-key.txt\"",
    "prepare": "husky"
  },
  "keywords": [
    "notion",
    "chrome-extension",
    "web-clipper",
    "highlight",
    "save-to-notion"
  ],
  "browserslist": [
    "last 2 Chrome versions"
  ],
  "author": "Cow Chan",
  "license": "GPL-3.0",
  "type": "commonjs",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "bugs": {
    "url": "https://github.com/cowcfj/save-to-notion/issues"
  },
  "homepage": "https://github.com/cowcfj/save-to-notion",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@playwright/test": "^1.58.2",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "babel-jest": "^30.2.0",
    "baseline-browser-mapping": "^2.10.0",
    "eslint-plugin-compat": "^7.0.2",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^64.0.0",
    "husky": "^9.1.6",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.0",
    "prettier": "^3.8.3",
    "rollup": "^4.60.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "v8-to-istanbul": "^9.3.0"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@notionhq/client": "5.11.0"
  },
  "overrides": {
    "glob@7": {
      "minimatch": "^3.1.3"
    },
    "test-exclude": {
      "minimatch": "^3.1.3"
    },
    "eslint": {
      "minimatch": "^3.1.3"
    },
    "@eslint/config-array": {
      "minimatch": "^3.1.3"
    },
    "@eslint/eslintrc": {
      "minimatch": "^3.1.3"
    },
    "glob@10": {
      "minimatch": "^9.0.6"
    },
    "@typescript-eslint/typescript-estree": {
      "minimatch": "^9.0.6"
    },
    "eslint-plugin-sonarjs": {
      "minimatch": ">=10.2.3"
    }
  },
  "lint-staged": {
    "*.config.js": [
      "prettier --write"
    ],
    "*.js": [
      "prettier --write",
      "eslint --fix --no-warn-ignored"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
