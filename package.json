{
  "name": "notion-smart-clipper",
  "version": "2.81.1",
  "description": "智能網頁擷取工具，支持網站 Icon、封面圖提取、增強的圖片提取、模板自定義、多顏色標註功能，一鍵保存到 Notion。",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "jest --config jest.config.js",
    "test:watch": "jest --config jest.config.js --watch",
    "test:coverage": "npm run test:coverage:native-esm:assert",
    "test:coverage:native-esm": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.native-esm.config.cjs --ci --coverage",
    "test:coverage:native-esm:assert": "npm run test:coverage:native-esm && node tools/assert-native-esm-line-hits.mjs --summary-json coverage/native-esm/line-hit-summary.json --summary-md coverage/native-esm/line-hit-summary.md",
    "test:coverage:native-esm:scope-parity": "node tools/report-native-esm-scope-parity.mjs --summary-json coverage/native-esm/scope-parity-summary.json --summary-md coverage/native-esm/scope-parity-summary.md",
    "test:quick": "jest --config jest.config.js --onlyChanged",
    "test:native": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.native-default.config.cjs",
    "test:quick:native": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.native-default.config.cjs --onlyChanged",
    "test:native:blockers": "node tools/report-native-default-runner-blockers.mjs --summary-json coverage/native-default/blocker-classification-summary.json --summary-md coverage/native-default/blocker-classification-summary.md",
    "test:ci": "npm run test:coverage:native-esm:assert",
    "test:e2e": "npm run build:prod && playwright test --project=chromium",
    "test:e2e:ui": "playwright test --ui --project=chromium",
    "perf:e2e": "npm run build:prod && playwright test --project=perf",
    "test:all": "npm run test:coverage && npm run test:e2e",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:report": "eslint . --format json --output-file docs/reports/eslint_report.json",
    "lint:knip": "knip",
    "format": "prettier --write \"**/*.{js,json,md,html}\"",
    "format:check": "prettier --check \"**/*.{js,json,md,html}\"",
    "postinstall": "node scripts/postinstall.js && npm run build",
    "build": "rollup -c rollup/all.config.mjs",
    "build:watch": "rollup -c rollup/all.config.mjs -w",
    "build:prod": "NODE_ENV=production rollup -c rollup/all.config.mjs",
    "build:prod:analyze": "ANALYZE_BUNDLE=true NODE_ENV=production rollup -c rollup/all.config.mjs",
    "build:content": "rollup -c rollup/content.config.mjs",
    "build:content:watch": "rollup -c rollup/content.config.mjs -w",
    "build:content:prod": "NODE_ENV=production rollup -c rollup/content.config.mjs",
    "build:all": "npm run build",
    "build:all:prod": "NODE_ENV=production npm run build:prod",
    "dev": "npm run build:watch",
    "ext": "npm run build:prod && npm run package:local-unpacked",
    "package:local-unpacked": "bash tools/package-extension.sh --unpacked-dir=.tmp/extension-unpacked --skip-zip --manifest-key-file=\"$HOME/.config/notion-chrome/dev-extension-public-key.txt\"",
    "prepare": "husky"
  },
  "keywords": [
    "notion",
    "chrome-extension",
    "web-clipper",
    "highlight",
    "save-to-notion"
  ],
  "browserslist": [
    "last 2 Chrome versions"
  ],
  "author": "Cow Chan",
  "license": "GPL-3.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "bugs": {
    "url": "https://github.com/cowcfj/save-to-notion/issues"
  },
  "homepage": "https://github.com/cowcfj/save-to-notion",
  "devDependencies": {
    "@asamuzakjp/css-color": "^5.0.1",
    "@jest/globals": "^30.2.0",
    "@playwright/test": "^1.61.1",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@swc/core": "^1.15.43",
    "@swc/jest": "^0.2.39",
    "eslint": "^10.6.0",
    "eslint-plugin-compat": "^7.0.2",
    "eslint-plugin-jest": "^29.15.4",
    "eslint-plugin-jsdoc": "^63.0.10",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-regexp": "^3.1.1",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-sonarjs": "^4.1.0",
    "eslint-plugin-unicorn": "^69.0.0",
    "husky": "^9.1.6",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jsdom": "^28.1.0",
    "knip": "^6.14.2",
    "lint-staged": "^16.3.0",
    "prettier": "^3.9.4",
    "rollup": "^4.62.2",
    "rollup-plugin-visualizer": "^7.0.1"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@notionhq/client": "5.11.0",
    "dompurify": "^3.4.9"
  },
  "overrides": {
    "glob@7": {
      "minimatch": "^3.1.3"
    },
    "test-exclude": {
      "minimatch": "^3.1.3"
    },
    "eslint": {
      "minimatch": "^3.1.3"
    },
    "@eslint/config-array": {
      "minimatch": "^3.1.3"
    },
    "@eslint/eslintrc": {
      "minimatch": "^3.1.3"
    },
    "glob@10": {
      "minimatch": "^9.0.6",
      "minipass": "7.1.2"
    },
    "@typescript-eslint/typescript-estree": {
      "minimatch": "^9.0.6"
    },
    "eslint-plugin-sonarjs": {
      "minimatch": ">=10.2.3"
    }
  },
  "lint-staged": {
    "*.config.js": [
      "prettier --write"
    ],
    "*.js": [
      "prettier --write",
      "eslint --fix --no-warn-ignored"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
